z-index:100;
}

.logo{
font-size:32px;
font-weight:bold;
color:#22c55e;
}

nav{
display:flex;
gap:15px;
}

nav button{
padding:10px 20px;
background:#1f2937;
border:none;
border-radius:12px;
color:white;
cursor:pointer;
font-size:15px;
transition:.2s;
}

nav button:hover{
background:#22c55e;
color:black;
}

.container{
padding:110px 25px 25px;
}

.page{display:none;}
.active{display:block;}

.hero{
height:350px;
border-radius:25px;
background:linear-gradient(135deg,#22c55e,#14532d);
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
text-align:center;
margin-bottom:35px;
}

.hero h1{font-size:65px;margin-bottom:10px;}
.hero p{font-size:22px;}

.total-games{
margin-top:20px;
padding:15px 30px;
background:#111827;
border:2px solid #22c55e;
border-radius:20px;
font-size:24px;
font-weight:bold;
}

.section-title{
font-size:34px;
margin-bottom:20px;
color:#22c55e;
}

.games-grid{
display:grid;
grid-template-columns:repeat(auto-fill,minmax(250px,1fr));
gap:20px;
margin-bottom:45px;
}

.game-card{
background:#111827;
border-radius:20px;
overflow:hidden;
border:2px solid transparent;
transition:.2s;
}

.game-card:hover{
transform:translateY(-5px);
border-color:#22c55e;
}

.game-card img{
width:100%;
height:160px;
object-fit:cover;
background:#000;
}

.game-info{padding:15px;}

.game-title{font-size:22px;font-weight:bold;margin-bottom:10px;}

.game-desc{font-size:14px;opacity:.8;margin-bottom:15px;}

.play-btn{
width:100%;
padding:12px;
border:none;
border-radius:12px;
background:#22c55e;
font-weight:bold;
cursor:pointer;
}

.search{
width:100%;
padding:15px;
border:none;
border-radius:15px;
background:#1f2937;
color:white;
font-size:16px;
margin-bottom:30px;
}

.board{
background:#111827;
padding:20px;
border-radius:20px;
margin-bottom:30px;
line-height:1.8;
}

#gameTopBar{
position:fixed;
top:0;
left:0;
width:100%;
height:65px;
background:#111827;
display:none;
align-items:center;
justify-content:space-between;
padding:0 20px;
z-index:1001;
border-bottom:2px solid #22c55e;
}

#currentGameName{
font-size:22px;
font-weight:bold;
color:#22c55e;
}

.top-buttons{display:flex;gap:10px;}

.top-buttons button{
padding:10px 18px;
border:none;
border-radius:12px;
font-weight:bold;
cursor:pointer;
}

#fullscreenBtn{background:#22c55e;}
#closeBtn{background:red;color:white;}

iframe{
position:fixed;
top:65px;
left:0;
width:100%;
height:calc(100% - 65px);
border:none;
display:none;
z-index:1000;
background:black;
}
</style>
