const featuredGrid = document.getElementById("featuredGrid");

function createCard(game){
const card = document.createElement("div");
card.className = "game-card";

card.innerHTML = `
<img src="${game.image}">
<div class="game-info">
<div class="game-title">${game.name}</div>
<div class="game-desc">${game.description}</div>
<button class="play-btn">Play</button>
`;

card.querySelector(".play-btn").onclick = () => launchGame(game);
return card;
}

function renderGames(list){
arcadeGrid.innerHTML = "";
actionGrid.innerHTML = "";
appsGrid.innerHTML = "";
toolsGrid.innerHTML = "";

list.forEach(game=>{
const card = createCard(game);

if(game.category==="Arcade") arcadeGrid.appendChild(card);
else if(game.category==="Action") actionGrid.appendChild(card);
else if(game.category==="Apps") appsGrid.appendChild(card);
else if(game.category==="Tools") toolsGrid.appendChild(card);
});
}

function renderFeatured(){
featuredGrid.innerHTML = "";
games.slice(0,3).forEach(g=>featuredGrid.appendChild(createCard(g)));
}

function launchGame(game){
const frame = document.getElementById("gameFrame");
frame.src = game.url;
frame.style.display = "block";

document.getElementById("gameTopBar").style.display = "flex";
document.getElementById("currentGameName").innerText = game.name;
}

document.getElementById("closeBtn").onclick = () => {
gameFrame.style.display = "none";
gameFrame.src = "";
gameTopBar.style.display = "none";
};

document.getElementById("fullscreenBtn").onclick = () => {
const frame = document.getElementById("gameFrame");
if(frame.requestFullscreen) frame.requestFullscreen();
};

function showPage(id){
document.querySelectorAll(".page").forEach(p=>p.classList.remove("active"));
document.getElementById(id).classList.add("active");
}

document.getElementById("search").addEventListener("input",e=>{
const val = e.target.value.toLowerCase();
renderGames(games.filter(g=>g.name.toLowerCase().includes(val)));
});

document.getElementById("totalGames").innerText = games.length;

renderGames(games);
renderFeatured();

/* background animation */
const canvas = document.getElementById("bg");
const ctx = canvas.getContext("2d");
canvas.width = innerWidth;
canvas.height = innerHeight;

let particles = [];
for(let i=0;i<120;i++){
particles.push({
x:Math.random()*canvas.width,
y:Math.random()*canvas.height,
r:Math.random()*3,
dx:(Math.random()-.5),
dy:(Math.random()-.5)
});
}

function animate(){
ctx.clearRect(0,0,canvas.width,canvas.height);

particles.forEach(p=>{
ctx.beginPath();
ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
ctx.fillStyle="#22c55e";
ctx.fill();

p.x+=p.dx;
p.y+=p.dy;

if(p.x<0||p.x>canvas.width)p.dx*=-1;
if(p.y<0||p.y>canvas.height)p.dy*=-1;
});

requestAnimationFrame(animate);
}
animate();
</script>

